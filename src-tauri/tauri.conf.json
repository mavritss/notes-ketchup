{
  "$schema": "../node_modules/@tauri-apps/cli/config.schema.json",
  "productName": "Notes Ketchup",
  "version": "0.1.0",
  "identifier": "local.notes-ketchup.desktop",
  "build": {
    "beforeDevCommand": "npm run dev:vite",
    "devUrl": "http://127.0.0.1:1420",
    "beforeBuildCommand": "npm run build:vite",
    "frontendDist": "../dist"
  },
  "app": {
    "windows": [
      {
        "label": "main",
        "title": "Notes Ketchup",
        "width": 356,
        "height": 274,
        "center": true,
        "resizable": false,
        "fullscreen": false,
        "decorations": false,
        "transparent": false,
        "shadow": true,
        "alwaysOnTop": true,
        "skipTaskbar": false,
        "visible": true
      }
    ],
    "security": {
      "csp": null
    }
  },
  "bundle": {
    "active": true,
    "targets": "all",
    "icon": [
      "icons/icon.ico"
    ]
  }
}
